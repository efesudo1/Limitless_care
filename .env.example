# PostgreSQL (docker-compose ile aynı değerler)
DATABASE_URL=postgresql://limitless:limitless_dev_password@localhost:5432/limitlesscare?schema=public

# Backend
PORT=4000
NODE_ENV=development

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Owner (seed.ts ilk owner hesabını oluşturur)
OWNER_EMAIL=owner@limitlesscare.local
OWNER_PASSWORD=Owner!2024Dev

# Reports
REPORTS_DIR=./uploads/reports
